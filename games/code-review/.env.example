# ============================================================================
# Game Configuration
# ============================================================================
# Server URL
# Leave blank for default local dev so phones use the game origin + Vite proxy.
# Set this only when you intentionally want a non-default backend (for example production).
VITE_AIR_JAM_SERVER_URL=

# Public App ID - optional for local development (not required when using local server)
# Required for production - get from the Air Jam platform
VITE_AIR_JAM_APP_ID=

# Optional stronger signed host-grant mode
# Set this when your static game fetches a short-lived host grant from your own backend/edge route
VITE_AIR_JAM_HOST_GRANT_ENDPOINT=

# HTTPS host used only by `pnpm run dev -- --secure --secure-mode=tunnel`
# Set by `pnpm run secure:init -- --mode=tunnel`
AIR_JAM_SECURE_PUBLIC_HOST=

# Named Cloudflare tunnel used only by `pnpm run dev -- --secure --secure-mode=tunnel`
# Set by `pnpm run secure:init -- --mode=tunnel`
CLOUDFLARE_TUNNEL_NAME=

# Soniox API key (needed for voice controls in controller)
VITE_SONIOX_API_KEY=

# Input mode: "gyro" or "voice"
# Default: voice (sound-based)
VITE_INPUT_MODE=voice
