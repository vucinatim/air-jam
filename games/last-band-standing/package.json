{
  "name": "last-band-standing",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "create-airjam dev",
    "dev:server": "create-airjam dev --server-only",
    "secure:init": "create-airjam secure:init",
    "dev:secure": "create-airjam dev --secure",
    "logs": "air-jam-server logs",
    "ai-pack:status": "create-airjam ai-pack status --dir .",
    "ai-pack:diff": "create-airjam ai-pack diff --dir .",
    "ai-pack:update": "create-airjam ai-pack update --dir .",
    "lint": "eslint .",
    "build": "tsc -p tsconfig.json && vite build",
    "release:bundle": "create-airjam release bundle --dir .",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@air-jam/sdk": "workspace:*",
    "@fontsource-variable/outfit": "^5.2.8",
    "@lottiefiles/dotlottie-react": "^0.18.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.35.2",
    "lucide-animated": "^1.0.0",
    "lucide-react": "^0.577.0",
    "mini-svg-data-uri": "^1.4.4",
    "motion": "^12.35.2",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.0.0",
    "shadcn": "^4.0.5",
    "simplex-noise": "^4.0.3",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@air-jam/server": "workspace:*",
    "@eslint/js": "^9.39.1",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "create-airjam": "workspace:*",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "tailwindcss": "^4.0.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^6.0.0",
    "vitest": "^4.1.0"
  }
