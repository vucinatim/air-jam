# AirJam server endpoint used by the SDK host/controller connections.
VITE_AIR_JAM_SERVER_URL=http://localhost:4000

# Public host used to generate controller join QR URLs.
# Use a LAN IP in local dev so phones can open it.
VITE_AIR_JAM_PUBLIC_HOST=http://192.168.0.100:5173

# Required when server auth is enabled (e.g. DATABASE_URL / master-key mode).
VITE_AIR_JAM_PUBLIC_KEY=replace-with-valid-public-key
