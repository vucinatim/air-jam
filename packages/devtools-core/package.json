{
  "name": "@air-jam/devtools-core",
  "version": "0.9.0",
  "description": "Shared Air Jam devtools operations for repo CLIs, MCP adapters, and generated projects",
  "private": true,
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vucinatim/air-jam.git",
    "directory": "packages/devtools-core"
  },
  "homepage": "https://github.com/vucinatim/air-jam#readme",
  "bugs": {
    "url": "https://github.com/vucinatim/air-jam/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./agent": {
      "types": "./dist/agent.d.ts",
      "import": "./dist/agent.js"
    },
    "./context": {
      "types": "./dist/context.d.ts",
      "import": "./dist/context.js"
    },
    "./dev": {
      "types": "./dist/dev.d.ts",
      "import": "./dist/dev.js"
    },
    "./game-session": {
      "types": "./dist/game-session.d.ts",
      "import": "./dist/game-session.js"
    },
    "./games": {
      "types": "./dist/games.d.ts",
      "import": "./dist/games.js"
    },
    "./logs": {
      "types": "./dist/logs.d.ts",
      "import": "./dist/logs.js"
    },
    "./platform-auth": {
      "types": "./dist/platform-auth.d.ts",
      "import": "./dist/platform-auth.js"
    },
    "./platform-game-media": {
      "types": "./dist/platform-game-media.d.ts",
      "import": "./dist/platform-game-media.js"
    },
    "./platform-games": {
      "types": "./dist/platform-games.d.ts",
      "import": "./dist/platform-games.js"
    },
    "./quality": {
      "types": "./dist/quality.d.ts",
      "import": "./dist/quality.js"
    },
    "./release": {
      "types": "./dist/release.d.ts",
      "import": "./dist/release.js"
    },
    "./visual": {
      "types": "./dist/visual.d.ts",
      "import": "./dist/visual.js"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "node ../../scripts/ensure-workspace-package-build.mjs @air-jam/sdk && node ../../scripts/ensure-workspace-package-build.mjs @air-jam/harness && tsup",
    "test": "node ../../scripts/ensure-workspace-package-build.mjs @air-jam/sdk && node ../../scripts/ensure-workspace-package-build.mjs @air-jam/harness && tsup && vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "typecheck": "node ../../scripts/ensure-workspace-package-build.mjs @air-jam/sdk && node ../../scripts/ensure-workspace-package-build.mjs @air-jam/harness && tsc --noEmit && tsc -p tests/tsconfig.json --noEmit"
  },
  "dependencies": {
    "@air-jam/harness": "workspace:^",
    "@air-jam/sdk": "workspace:^",
    "socket.io-client": "^4.8.1",
    "tsx": "^4.20.6",
    "yauzl": "^3.2.1",
    "yazl": "^3.3.1",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/yauzl": "^2.10.3",
    "@types/yazl": "^2.4.5",
    "socket.io": "^4.8.1",
    "tsup": "^8.5.1",
    "typescript": "~5.9.3",
    "vitest": "^3.2.4"
  }
}
