# ============================================================================
# Game Configuration
# ============================================================================
# Server URL - defaults to localhost:4000 in development
# For production, set to your official Air Jam server URL: wss://api.air-jam.app
VITE_AIR_JAM_SERVER_URL=http://localhost:4000

# Public App ID - optional for local development (not required when using local server)
# Required for production - get from the Air Jam platform
VITE_AIR_JAM_APP_ID=

# Optional stronger signed host-grant mode
# Set this when your static game fetches a short-lived host grant from your own backend/edge route
VITE_AIR_JAM_HOST_GRANT_ENDPOINT=

# HTTPS host used only by `pnpm run dev:secure` (set by `pnpm run secure:init`)
# Example: https://my-game-dev.example.com
AIR_JAM_SECURE_PUBLIC_HOST=

# Named Cloudflare tunnel used by `pnpm run dev:secure`
# Example: my-airjam-dev
CLOUDFLARE_TUNNEL_NAME=
