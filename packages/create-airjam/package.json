{
  "name": "create-airjam",
  "version": "1.0.0",
  "description": "CLI to scaffold Air Jam game projects",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vucinatim/air-jam.git",
    "directory": "packages/create-airjam"
  },
  "homepage": "https://github.com/vucinatim/air-jam#readme",
  "bugs": {
    "url": "https://github.com/vucinatim/air-jam/issues"
  },
  "keywords": [
    "air-jam",
    "cli",
    "scaffold",
    "template",
    "game",
    "multiplayer",
    "create-airjam",
    "boilerplate",
    "starter"
  ],
  "bin": {
    "create-airjam": "./dist/index.js"
  },
  "files": [
    "dist",
    "templates",
    "template-version-manifest.json"
  ],
  "scripts": {
    "build": "node scripts/generate-template-version-manifest.mjs && tsup",
    "dev": "tsup --watch",
    "smoke": "node scripts/smoke-test.mjs",
    "smoke:registry": "node scripts/smoke-test.mjs --source=registry",
    "smoke:tarball": "node scripts/smoke-test.mjs --source=tarball",
    "smoke:workspace": "node scripts/smoke-test.mjs --source=workspace",
    "prepublishOnly": "node scripts/prepublish.js && pnpm build"
  },
  "dependencies": {
    "commander": "^14.0.0",
    "fs-extra": "^11.3.0",
    "kleur": "^4.1.5",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/prompts": "^2.4.9",
    "tsup": "^8.5.1",
    "tsx": "^4.19.2",
    "typescript": "~5.9.3"
  }
}
