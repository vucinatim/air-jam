{
  "name": "air-capture",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm exec airjam dev",
    "topology": "pnpm exec airjam topology",
    "secure:init": "pnpm exec airjam secure:init",
