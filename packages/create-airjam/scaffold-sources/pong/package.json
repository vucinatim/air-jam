{
  "name": "my-airjam-game",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node ./scripts/dev.mjs",
    "dev:server": "node ./scripts/dev.mjs --server-only",
    "dev:secure": "node ./scripts/dev.mjs --secure",
    "logs": "air-jam-server logs",
    "secure:init": "node ./scripts/secure-init.mjs",
    "build": "tsc && vite build",
    "ai-pack:status": "create-airjam ai-pack status --dir .",
    "ai-pack:diff": "create-airjam ai-pack diff --dir .",
    "ai-pack:update": "create-airjam ai-pack update --dir .",
    "release:bundle": "create-airjam release bundle --dir .",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@air-jam/sdk": "workspace:*",
    "@tabler/icons-react": "^3.41.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-icons": "^5.6.0",
    "react-router-dom": "^7.0.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@air-jam/server": "workspace:*",
    "@eslint/js": "^9.39.1",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "create-airjam": "workspace:*",
    "globals": "^16.5.0",
    "tailwindcss": "^4.0.0",
    "typescript": "~5.6.0",
    "typescript-eslint": "^8.46.4",
    "vite": "^6.0.0",
    "vitest": "^3.2.4"
  }
}
