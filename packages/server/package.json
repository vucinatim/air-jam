{
  "name": "@air-jam/server",
  "version": "0.9.2",
  "description": "Air Jam game server for local development and production",
  "private": false,
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vucinatim/airjam.git",
    "directory": "packages/server"
  },
  "homepage": "https://github.com/vucinatim/airjam#readme",
  "bugs": {
    "url": "https://github.com/vucinatim/airjam/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "air-jam-server": "./bin/air-jam-server.mjs"
  },
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./vite-config": {
      "types": "./src/project-cli/vite-config.d.mts",
      "import": "./src/project-cli/vite-config.mjs"
    }
  },
  "files": [
    "bin",
    "dist",
    "src/project-cli/vite-config.mjs",
    "src/project-cli/vite-config.d.mts",
    "src/project-cli/vite-https.mjs",
    "src/project-cli/vite-https.d.mts"
  ],
  "scripts": {
    "dev": "tsx src/main.ts",
    "logs:dev": "tsx scripts/dev-logs.ts",
    "analytics:rebuild": "tsx scripts/runtime-usage-rebuild.ts",
    "start": "node ./bin/air-jam-server.mjs",
    "build": "node ../../scripts/ensure-workspace-package-build.mjs @air-jam/devtools-core && node ../../scripts/ensure-workspace-package-build.mjs @air-jam/harness && tsup",
    "test": "node ../../scripts/ensure-workspace-package-build.mjs @air-jam/devtools-core && node ../../scripts/ensure-workspace-package-build.mjs @air-jam/harness && vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "perf:sanity": "tsx scripts/perf-sanity.ts",
    "typecheck": "node ../../scripts/ensure-workspace-package-build.mjs @air-jam/devtools-core && node ../../scripts/ensure-workspace-package-build.mjs @air-jam/harness && tsc --noEmit && tsc -p tests/tsconfig.json --noEmit",
    "prepublishOnly": "pnpm build",
    "prepack": "node ../../scripts/release/prepare-public-package-manifest.mjs",
    "postpack": "node ../../scripts/release/restore-public-package-manifest.mjs"
  },
  "dependencies": {
    "@air-jam/sdk": "workspace:*",
    "color": "^5.0.3",
    "commander": "^14.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.0",
    "express": "^4.21.2",
    "pino": "^10.3.1",
    "postgres": "^3.4.7",
    "socket.io": "^4.8.1",
    "uuid": "^13.0.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@air-jam/devtools-core": "workspace:^",
    "@air-jam/env": "workspace:^",
    "@air-jam/harness": "workspace:^",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^24.10.1",
    "@types/uuid": "^11.0.0",
    "socket.io-client": "^4.8.1",
    "tsup": "^8.5.1",
    "tsx": "^4.19.2",
    "typescript": "~5.9.3",
    "vitest": "^3.2.4"
  }
}
