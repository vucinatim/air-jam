{
  "name": "@air-jam/mcp-server",
  "version": "0.9.2",
  "description": "Official Air Jam MCP server for project inspection, logs, quality gates, and visual artifacts",
  "private": false,
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vucinatim/airjam.git",
    "directory": "packages/mcp-server"
  },
  "homepage": "https://github.com/vucinatim/airjam#readme",
  "bugs": {
    "url": "https://github.com/vucinatim/airjam/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "airjam-mcp": "./bin/airjam-mcp.mjs"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "import": "./dist/config.js"
    }
  },
  "files": [
    "bin",
    "dist",
    "src"
  ],
  "scripts": {
    "build": "node ../../scripts/ensure-workspace-package-build.mjs @air-jam/devtools-core && tsup",
    "prepack": "node ../../scripts/release/prepare-public-package-manifest.mjs",
    "postpack": "node ../../scripts/release/restore-public-package-manifest.mjs",
    "test": "node ../../scripts/ensure-workspace-package-build.mjs @air-jam/devtools-core && tsup && vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "typecheck": "node ../../scripts/ensure-workspace-package-build.mjs @air-jam/devtools-core && tsup && tsc --noEmit && tsc -p tests/tsconfig.json --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "socket.io-client": "^4.8.1",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@air-jam/devtools-core": "workspace:^",
    "@types/node": "^24.10.1",
    "tsup": "^8.5.1",
    "tsx": "^4.20.6",
    "typescript": "~5.9.3",
    "vitest": "^3.2.4"
  }
}
