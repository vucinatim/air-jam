{
  "name": "@air-jam/mcp-server",
  "version": "1.0.0",
  "description": "Official Air Jam MCP server for project inspection, logs, quality gates, and visual artifacts",
  "private": false,
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vucinatim/air-jam.git",
    "directory": "packages/mcp-server"
  },
  "homepage": "https://github.com/vucinatim/air-jam#readme",
  "bugs": {
    "url": "https://github.com/vucinatim/air-jam/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "airjam-mcp": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "pnpm --filter @air-jam/devtools-core build && tsup",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "typecheck": "pnpm --filter @air-jam/devtools-core build && tsc --noEmit && tsc -p tests/tsconfig.json --noEmit"
  },
  "dependencies": {
    "@air-jam/devtools-core": "workspace:^",
    "@modelcontextprotocol/sdk": "1.29.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsup": "^8.5.1",
    "typescript": "~5.9.3",
    "vitest": "^3.2.4"
  }
}
